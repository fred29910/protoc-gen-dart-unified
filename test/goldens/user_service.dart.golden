// ignore_for_file: type=lint
import 'package:protoc_gen_dart_unified/src/runtime/transport.dart';
import 'package:protoc_gen_dart_unified/src/runtime/client_options.dart';
import 'package:protoc_gen_dart_unified/src/runtime/transport_factory.dart';
import '../user.pb.dart';

abstract class UserService {
  Future<User> getUser(GetUserRequest request);
  Future<User> createUser(CreateUserRequest request);
}

class UnifiedUserService implements UserService {
  UnifiedUserService(this._transport);

  final Transport _transport;

  @override
  Future<User> getUser(GetUserRequest request) async {
    // HTTP get /v1/users/{id}
    final response = await _transport.unaryCall<User>(
      'UserService',
      'getUser',
      request,
      options: RpcCallOptions(
        httpMethod: 'get',
        httpPath: '/v1/users/${request.id}',
      ),
    );
    return response;
  }

  @override
  Future<User> createUser(CreateUserRequest request) async {
    // HTTP post /v1/users
    final response = await _transport.unaryCall<User>(
      'UserService',
      'createUser',
      request,
      options: RpcCallOptions(
        httpMethod: 'post',
        httpPath: '/v1/users',
        httpBody: request.toProto3Json(),
        httpQueryParams: {'name': request.name, 'email': request.email},
      ),
    );
    return response;
  }
}

class ApiSdk {
  ApiSdk(ClientOptions options)
    : userService = UnifiedUserService(createTransport(options.endpoint)!);

  UserService userService;
}
